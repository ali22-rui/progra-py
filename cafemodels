class productoBase():
    def __init__(self,idProducto,nombre,precioBase):
        self.idProducto=idProducto
        self.nombre=nombre
        self.precioBase=precioBase


class bebida(productoBase):
    def __init__(self,idProducto,nombre,precioBase, medida,temperatura):
        self.idProducto=idProducto
        self.nombre=nombre
        self.precioBase=precioBase
        self.medida=medida
        self.temperatura=temperatura
        self.modificadores=[]

    def agregarExtra(self,extra):
        self.modificadores.append(extra)

    def calcularPrecioFinal(self):
        precio=self.precioBase + len(self.modificadores)*5
        print("precio final:",precio)





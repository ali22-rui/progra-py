class empleado:
    def __init__(self,idPersona,nombre,email,tel,idEmp,rol,hor):
        self.id_p=idPersona
        self.nombre_completo=nombre
        self.email=email
        self.telefono=tel
        self.id_e=idEmp
        self.puesto=rol
        self.horario=hor

class pelicula:
    def __init__(self,titulo,duracion,claf,genero):
        self.titulo=titulo
        self.duracion=duracion
        self.clasif=claf
        self.gen=genero
    def obtenerSinopsis(self):
        return "pelicula de genero "+self.gen+": "+self.titulo

class sala:

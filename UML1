        self.vip=esVip

class producto:
    def __init__(self,codigoProd,nombre,precio):
        self.cod=codigoProd
        self.n=nombre
        self.p=precio

class promocion:
    def __init__(self,codigo,descr,porcentajeDesc,expiracion):
        self.c=codigo
        self.p=porcentajeDesc
    def aplicarDescuento(self,monto):
        return monto-(monto*(self.p/100))

